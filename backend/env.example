# Deprecated file name. Use .env instead.
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=CHANGE_ME

# Transport mode:
# - postgres (default): direct DB sync via psycopg2
# - edge: sync via HTTPS Edge Function (recommended when TCP 5432/6543 is blocked)
SYNC_TRANSPORT=postgres

# Edge Function settings (used when SYNC_TRANSPORT=edge)
EDGE_FUNCTION_URL=
EDGE_FUNCTION_BEARER_TOKEN=
EDGE_FUNCTION_SHARED_SECRET=
EDGE_FUNCTION_TIMEOUT_SECONDS=120
EDGE_FUNCTION_CHUNK_SIZE=1000
